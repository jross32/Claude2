# WebScraper Pro — local environment template
# Copy this file to `.env` and fill in only the values you actually use.
# `.env` is gitignored; this file is safe to commit.

# ── App server ──────────────────────────────────────────────────────────────
PORT=3000

# Optional known-site credentials used by the app for poolplayers.com / APA.
# Leave blank if you do not want automatic credential injection.
APA_USERNAME=
APA_PASSWORD=

# ── Browser / network overrides ─────────────────────────────────────────────
# Optional custom Chromium/Chrome executable for Playwright.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# Optional proxy values. Uncomment and set only if you need them.
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080

# ── Tor integration (optional) ───────────────────────────────────────────────
# Set useTor:true on any scrape to route traffic through the local Tor daemon.
# Install Tor: https://www.torproject.org/download/tor/  (Expert Bundle for Windows)
# Run: tor.exe   — listens on SOCKS5 port 9050 and control port 9051 by default.
# TOR_SOCKS_HOST=127.0.0.1
# TOR_SOCKS_PORT=9050
# TOR_CONTROL_HOST=127.0.0.1
# TOR_CONTROL_PORT=9051
# TOR_CONTROL_PASSWORD=         # leave blank if you haven't set HashedControlPassword in torrc
# TOR_ROTATE_EVERY=10           # rotate circuit every N pages (default: 10)

# ── Redis integration (optional) ─────────────────────────────────────────────
# Enables two features when set:
#   1. Per-domain rate limiting across ALL parallel workers (replaces flat politeDelay)
#   2. Cross-session URL dedup when redisDedupe:true is passed to a scrape
# Install Redis: winget install Redis.Redis   (or run: docker run -p 6379:6379 redis:alpine)
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_VISITED_TTL_SEC=604800  # how long to remember scraped URLs (default: 7 days)

# ── MCP server / AI analysis ─────────────────────────────────────────────────
# research_url uses the Anthropic API for AI-powered analysis.
# Set ANTHROPIC_API_KEY to enable it. Without it, research_url falls back to
# keyword extraction (no LLM reasoning).
SCRAPER_URL=http://localhost:3000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_MS=60000

# ── Research tuning (optional) ─────────────────────────────────────────────
RESEARCH_FAST_MAX_PAGES=2
RESEARCH_DEEP_MAX_PAGES=4
RESEARCH_FAST_MAX_SNIPPETS=4
RESEARCH_DEEP_MAX_SNIPPETS=8
RESEARCH_FAST_SNIPPET_CHARS=180
RESEARCH_DEEP_SNIPPET_CHARS=260
RESEARCH_FAST_MAX_TOTAL_CHARS=7000
RESEARCH_DEEP_MAX_TOTAL_CHARS=18000
RESEARCH_FAST_MAX_HEADINGS=8
RESEARCH_DEEP_MAX_HEADINGS=14

# ── Test runner (optional) ─────────────────────────────────────────────────
TEST_SERVER_PORT=3311
