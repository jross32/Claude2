{
  "name": "web-scraper-app",
  "version": "2.5.3",
  "description": "Web scraper with GraphQL/API interception, auth support, and JSON export",
  "main": "src/server.js",
  "scripts": {
    "start": "node --max-old-space-size=4096 src/server.js",
    "dev": "nodemon --max-old-space-size=4096 src/server.js",
    "save": "node autosave.js",
    "test": "node tests/run.js smoke",
    "test:all": "node tests/run.js all",
    "release:engine": "node scripts/release-engine.js",
    "release:engine:dry": "node scripts/release-engine.js --dry-run --iterations 1 --verify \"node tests/run.js smoke\" --review-delay-ms 0 --allow-dirty",
    "release:engine:strict": "node scripts/release-engine.js --iterations 1 --verify \"node tests/run.js smoke\" --review-delay-ms 3000",
    "release:engine:autopush": "node scripts/release-engine.js --iterations 1 --verify \"node tests/run.js smoke\" --review-delay-ms 3000 --push-each --allow-dirty",
    "release:engine:loop": "node scripts/release-engine-loop.js --chunk-size 5 --target-total 10000 --allow-dirty --continue-on-failure",
    "release:engine:loop:dry": "node scripts/release-engine-loop.js --dry-run --chunk-size 2 --target-total 10 --allow-dirty"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "node-cron": "^3.0.3",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
