{
  "name": "web-scraper-app",
  "version": "1.0.0",
  "description": "Web scraper with GraphQL/API interception, auth support, and JSON export",
  "main": "src/server.js",
  "scripts": {
    "start": "node --max-old-space-size=4096 src/server.js",
    "dev": "nodemon --max-old-space-size=4096 src/server.js",
    "save": "node autosave.js",
    "test": "node tests/run.js smoke",
    "test:all": "node tests/run.js all"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "node-cron": "^3.0.3",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
